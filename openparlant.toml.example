# OpenParlant Agent OS — Example Configuration
# Copy to ~/.openparlant/config.toml and customize.

# API server settings
# api_key = ""                               # Set to enable Bearer auth (recommended)
# api_listen = "127.0.0.1:50051"             # HTTP API bind address (use 0.0.0.0 for public)

# Web dashboard login (POST /api/auth/login, same as frontend login page).
# password_hash is SHA-256 of the password, hex-encoded (not plaintext).
# After enabling, restart the daemon once so the platform admin row is synced to the DB.
#
# Option A — CLI writes [auth] for you (recommended):
#   openparlant auth bootstrap-admin --username admin
#
# Option B — set hash manually:
#   openparlant auth hash-password --password "YourSecurePassword"
#   # paste the printed hex into password_hash below
#
# [auth]
# enabled = true
# username = "admin"
# password_hash = ""                      # Paste hex from `openparlant auth hash-password` (required when enabled is true)
# session_ttl_hours = 168                 # Session lifetime in hours (default 7 days)


[default_model]
provider = "anthropic"                    # "anthropic", "gemini", "openai", "groq", "ollama", etc.
model = "claude-sonnet-4-20250514"        # Model identifier
api_key_env = "ANTHROPIC_API_KEY"         # Environment variable holding API key
# base_url = "https://api.anthropic.com"  # Optional: override API endpoint

[memory]
decay_rate = 0.05                         # Memory confidence decay rate
# sqlite_path = "~/.openparlant/data/openparlant.db"   # Optional: custom DB path (SQLite when no Postgres URL)

# PostgreSQL — shared store for runtime + control plane (optional; defaults to SQLite).
# Prefer split fields so passwords may contain "@" without breaking the URI.
# [database]
# host = "127.0.0.1"
# port = 5432
# user = "openparlant"
# password = "OPENFANG_PG_PASSWORD"   # Env var name; value from secrets.env then environment
#                                      # Preferred key; do not also set password_env
# dbname = "openparlant"               # Must be this key (alias: database = "...")
# ssl_mode = "disable"                  # Appended as ?sslmode=...
# Or a single URI (split fields ignored when non-empty):
# url = "postgresql://user:pass@host:5432/dbname"

# Legacy (still supported): [memory] database_url = "postgresql://..."

[network]
listen_addr = "127.0.0.1:4200"           # OFP listen address
# shared_secret = ""                      # Required for P2P authentication

# Session compaction (LLM-based context management)
# [compaction]
# threshold = 80                          # Compact when messages exceed this count
# keep_recent = 20                        # Keep this many recent messages after compaction
# max_summary_tokens = 1024               # Max tokens for LLM summary

# Usage tracking display
# usage_footer = "Full"                   # "Off", "Tokens", "Cost", or "Full"

# Channel adapters (configure tokens via environment variables)
# [telegram]
# bot_token_env = "TELEGRAM_BOT_TOKEN"
# allowed_users = []                      # Empty = allow all

# [discord]
# bot_token_env = "DISCORD_BOT_TOKEN"
# guild_ids = []                          # Empty = all guilds

# [slack]
# bot_token_env = "SLACK_BOT_TOKEN"
# app_token_env = "SLACK_APP_TOKEN"

# MCP server connections
# [[mcp_servers]]
# name = "filesystem"
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-filesystem", "/tmp"]
